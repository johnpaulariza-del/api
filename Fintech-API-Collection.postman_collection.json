    {
      "name": "Transactions - Successful",
      "item": [
        {
          "name": "Successful Transaction - Transfer 500 from ACC001 to ACC002",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"from_account\": 1,\n  \"to_account\": 2,\n  \"amount\": 500\n}"
            },
            "url": {
              "raw": "http://127.0.0.1:8000/api/transactions/",
              "protocol": "http",
              "host": [
                "127.0.0.1"
              ],
              "port": "8000",
              "path": [
                "api",
                "transactions",
                ""
              ]
            },
            "description": "Transfer 500 from Account 1 (ACC001: 5000 balance) to Account 2 (ACC002: 3000 balance). This should succeed. Expected: ACC001 becomes 4500, ACC002 becomes 3500"
          },
          "response": []
        },
        {
          "name": "Successful Transaction - Transfer 1000 from ACC003 to ACC001",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"from_account\": 3,\n  \"to_account\": 1,\n  \"amount\": 1000\n}"
            },
            "url": {
              "raw": "http://127.0.0.1:8000/api/transactions/",
              "protocol": "http",
              "host": [
                "127.0.0.1"
              ],
              "port": "8000",
              "path": [
                "api",
                "transactions",
                ""
              ]
            },
            "description": "Transfer 1000 from Account 3 (ACC003: 10000 balance) to Account 1 (ACC001: 4500 balance after previous transaction). This should succeed. Expected: ACC003 becomes 9000, ACC001 becomes 5500"
          },
          "response": []
        }
      ],
      "description": "Successful transaction tests that demonstrate correct balance updates"
    },
    {
      "name": "Transactions - Failed",
      "item": [
        {
          "name": "Failed Transaction - Insufficient Balance (ACC002 has 3500, trying to send 5000)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
