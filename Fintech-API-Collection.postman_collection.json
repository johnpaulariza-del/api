            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"from_account\": 2,\n  \"to_account\": 1,\n  \"amount\": 5000\n}"
            },
            "url": {
              "raw": "http://127.0.0.1:8000/api/transactions/",
              "protocol": "http",
              "host": [
                "127.0.0.1"
              ],
              "port": "8000",
              "path": [
                "api",
                "transactions",
                ""
              ]
            },
            "description": "Attempt to transfer 5000 from Account 2 (ACC002) which only has 3500 balance. This should FAIL with insufficient balance error. Balances should remain unchanged."
          },
          "response": []
        },
        {
          "name": "Failed Transaction - Negative Amount",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"from_account\": 1,\n  \"to_account\": 2,\n  \"amount\": -100\n}"
            },
            "url": {
              "raw": "http://127.0.0.1:8000/api/transactions/",
              "protocol": "http",
              "host": [
                "127.0.0.1"
              ],
              "port": "8000",
              "path": [
                "api",
                "transactions",
                ""
              ]
            },
            "description": "Attempt to transfer negative amount (-100). This should FAIL with validation error. Balances should remain unchanged."
          },
          "response": []
        }
      ],
      "description": "Failed transaction tests that demonstrate error handling and validation"
